---
import BaseLayout from './BaseLayout.astro';
import TechTag from '../components/TechTag.astro';
import StatusBadge from '../components/StatusBadge.astro';

interface Props {
  name: string;
  tagline: string;
  description: string;
  tech: string[];
  accent: string;
  status: 'live' | 'wip' | 'archived';
  liveUrl?: string;
  repoUrl?: string;
  screenshot?: string;
}

const {
  name,
  tagline,
  description,
  tech,
  accent,
  status,
  liveUrl,
  repoUrl,
  screenshot,
} = Astro.props;

const home = import.meta.env.BASE_URL;
const initials = name
  .split(/\s+/)
  .map((w) => w[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
---

<BaseLayout title={`${name} — App Launcher`} description={description} accent={accent}>
  <a
    href={home}
    class="mb-6 inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 transition hover:text-slate-900 dark:text-slate-400 dark:hover:text-white"
  >
    ← All apps
  </a>

  <article class="animate-fade-up">
    {/* Hero */}
    <div
      class="relative mb-8 overflow-hidden rounded-3xl border border-slate-200 dark:border-slate-800"
      style={`--accent:${accent}`}
    >
      <div
        class="relative h-56 w-full sm:h-72"
        style="background-image: linear-gradient(135deg, color-mix(in srgb, var(--accent) 85%, black) 0%, var(--accent) 100%)"
      >
        {
          screenshot ? (
            <img src={screenshot} alt={`${name} screenshot`} class="h-full w-full object-cover" />
          ) : (
            <div class="flex h-full w-full items-center justify-center">
              <span class="font-display text-7xl font-bold text-white/90">{initials}</span>
            </div>
          )
        }
        <div class="absolute right-4 top-4">
          <StatusBadge status={status} hosted={!!liveUrl} />
        </div>
      </div>
    </div>

    {/* Header block */}
    <div class="mb-8">
      <h1 class="font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        {name}
      </h1>
      <p class="mt-2 text-lg text-slate-600 dark:text-slate-400">{tagline}</p>

      <div class="mt-4 flex flex-wrap gap-2">
        {tech.map((t) => <TechTag label={t} />)}
      </div>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        {
          liveUrl ? (
            <a
              href={liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-xl px-5 py-2.5 font-semibold text-white shadow-sm transition hover:brightness-110"
              style={`background-color:${accent}`}
            >
              Launch app
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5h5v5m0-5L10 14M5 9v10h10" />
              </svg>
            </a>
          ) : (
            <span class="inline-flex items-center gap-2 rounded-xl border border-dashed border-slate-300 px-5 py-2.5 font-medium text-slate-500 dark:border-slate-600 dark:text-slate-400">
              Not publicly hosted
            </span>
          )
        }
        {
          repoUrl && (
            <a
              href={repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-xl border border-slate-200 px-5 py-2.5 font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
            >
              View source
            </a>
          )
        }
      </div>
    </div>

    {/* MDX body */}
    <div class="prose prose-slate max-w-none dark:prose-invert prose-headings:font-display prose-a:text-[var(--accent)]">
      <slot />
    </div>
  </article>
</BaseLayout>
