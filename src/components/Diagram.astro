---
// Lightweight architecture diagram: a flow of labeled boxes joined by arrows.
// Pure HTML/CSS — ships zero JavaScript and needs no build-time browser.
//
// Usage in MDX:
//   <Diagram
//     caption="Request flow"
//     nodes={[
//       { label: "Browser", kind: "external" },
//       { label: "Go API", sub: "REST/JSON" },
//       { label: "MySQL", kind: "store" },
//     ]}
//   />
interface Node {
  label: string;
  sub?: string;
  kind?: 'default' | 'store' | 'external' | 'service';
}
interface Props {
  nodes: Node[];
  caption?: string;
}
const { nodes, caption } = Astro.props;

const kindClass: Record<string, string> = {
  default:
    'border-slate-300 bg-white text-slate-800 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100',
  service:
    'border-[var(--page-accent,#6366f1)] bg-white text-slate-800 dark:bg-slate-800 dark:text-slate-100',
  store:
    'rounded-2xl border-slate-300 bg-slate-100 text-slate-700 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200',
  external:
    'border-dashed border-slate-400 bg-slate-50 text-slate-600 dark:border-slate-500 dark:bg-slate-900 dark:text-slate-300',
};
---
<figure class="not-prose my-6">
  <div class="flex flex-wrap items-center gap-x-2 gap-y-3 rounded-xl border border-slate-200 bg-slate-50/60 p-5 dark:border-slate-800 dark:bg-slate-900/60">
    {
      nodes.map((n, i) => (
        <>
          <div
            class={`flex min-w-[5.5rem] flex-col items-center rounded-lg border px-3 py-2 text-center text-sm font-semibold shadow-sm ${kindClass[n.kind ?? 'default']}`}
          >
            <span>{n.label}</span>
            {n.sub && (
              <span class="mt-0.5 text-[0.7rem] font-normal opacity-70">{n.sub}</span>
            )}
          </div>
          {i < nodes.length - 1 && (
            <span aria-hidden="true" class="select-none text-lg text-[var(--page-accent,#6366f1)]">
              →
            </span>
          )}
        </>
      ))
    }
  </div>
  {
    caption && (
      <figcaption class="mt-2 text-center text-xs text-slate-500 dark:text-slate-400">
        {caption}
      </figcaption>
    )
  }
</figure>
