---
// Client-rendered mermaid diagram. Pass `code` as a mermaid definition string.
// Rendering happens in the browser so the static build stays dependency-light.
interface Props {
  code: string;
}
const { code } = Astro.props;
---
<div class="not-prose my-6 overflow-x-auto rounded-xl border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-900">
  <pre class="mermaid text-center">{code}</pre>
</div>

<script>
  import mermaid from 'mermaid';

  const render = () => {
    const isDark = document.documentElement.classList.contains('dark');
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'default',
      securityLevel: 'strict',
    });
    const nodes = document.querySelectorAll<HTMLElement>('pre.mermaid');
    // Reset any previous render so re-runs (theme/nav) re-process cleanly.
    nodes.forEach((n) => {
      if (n.dataset.processed) {
        n.innerHTML = n.dataset.source ?? n.textContent ?? '';
        delete n.dataset.processed;
      } else {
        n.dataset.source = n.textContent ?? '';
      }
    });
    mermaid.run({ nodes });
  };

  render();
  document.addEventListener('astro:after-swap', render);
  // Re-render diagrams when the theme is toggled.
  const obs = new MutationObserver(render);
  obs.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });
</script>
