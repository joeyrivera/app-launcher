---
interface Props {
  label: string;
}
const { label } = Astro.props;
---
<span
  class="inline-flex items-center rounded-full border border-slate-200 bg-slate-100/70 px-2.5 py-0.5 text-xs font-medium text-slate-600 dark:border-slate-700 dark:bg-slate-800/70 dark:text-slate-300"
>
  {label}
</span>
